# LM Studio local server defaults
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_API_BASE=http://localhost:1234
LMSTUDIO_MODEL=ibm/granite-4-micro
LMSTUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
LMSTUDIO_CONTEXT_LENGTH=8000
LMSTUDIO_MAX_OUTPUT_TOKENS=512
LMSTUDIO_TEMPERATURE=0.3

# OpenAI-compatible clients require an API key value.
# LM Studio accepts a placeholder by default unless auth is enabled.
LMSTUDIO_API_KEY=lm-studio

# Native /api/v1 endpoints can use this if LM Studio auth is enabled.
LM_API_TOKEN=

# Anthropic-compatible local endpoint helper.
ANTHROPIC_API_KEY=lm-studio

# Optional model-management defaults.
LMSTUDIO_DOWNLOAD_MODEL=ibm/granite-4-micro
LMSTUDIO_LOAD_FLASH_ATTENTION=true

# Realtime backend defaults.
REALTIME_BACKEND_HOST=127.0.0.1
REALTIME_BACKEND_PORT=8787
REALTIME_BACKEND_URL=http://127.0.0.1:8787
REALTIME_BACKEND_TOKEN=change-me-local-token
REALTIME_STATE_PATH=.runtime/machine-state.json
REALTIME_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Local daemon defaults.
DAEMON_ID=cyntra-local-daemon
DAEMON_TICK_SECONDS=15
DAEMON_MODE=lmstudio-watch
DAEMON_RUN_SMOKE_TESTS=false
DAEMON_COMMAND_TIMEOUT_SECONDS=180
